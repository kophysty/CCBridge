# CCBridge — environment variables (template)
#
# Copy to `.env` and fill values. NEVER commit `.env`.
# CCBridge does not read these directly — they are required by the
# underlying CLIs (claude, codex). See ARCHITECTURE.md §6.1.
#
# Loading is up to you (direnv, dotenv, shell rc, etc.). CCBridge
# inherits the calling shell's environment via subprocess.

# ──────────────────────────────────────────────────────────────────
# Required for runtime
# ──────────────────────────────────────────────────────────────────

# Anthropic API key — used by Claude Code CLI (`claude --print ...`).
ANTHROPIC_API_KEY=

# OpenAI API key — used by Codex CLI (`codex exec ...`).
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────────
# Optional — Claude Code hook context
# ──────────────────────────────────────────────────────────────────
# Set automatically by Claude Code when running a hook. You normally
# don't set this manually; listed here for documentation only.
# CLAUDE_PROJECT_DIR=

# ──────────────────────────────────────────────────────────────────
# Optional — CCBridge dev overrides (future use)
# ──────────────────────────────────────────────────────────────────
# CCBRIDGE_LOG_LEVEL=INFO
# CCBRIDGE_CONFIG_PATH=
